{
  "name": "mdwow-cli",
  "version": "1.17.0",
  "description": "A beautiful live Markdown viewer for the terminal",
  "type": "module",
  "bin": {
    "mdwow": "dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "markdown",
    "cli",
    "tui",
    "viewer",
    "terminal",
    "ink",
    "live"
  ],
  "license": "MIT",
  "author": "tianhaoz95",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tianhaoz95/mdwow.git"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "tsx src/cli.tsx",
    "preview": "bash scripts/preview.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "beautiful-mermaid": "^1.1.3",
    "chokidar": "^3.6.0",
    "cli-highlight": "^2.1.11",
    "ink": "^5.0.1",
    "meow": "^13.2.0",
    "react": "^18.3.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "esbuild": "^0.24.0",
    "ink-testing-library": "^3.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
